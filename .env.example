# Optional debug dump for TTS A/B testing (disabled by default)
# When enabled, ElevenLabs source MP3 and decoded WAV are saved for comparison.
DEBUG_TTS_DUMP_AUDIO=false
DEBUG_TTS_DUMP_DIR=./debug_audio
# ─────────────────────────────────────────────────────────────────────────────
# Telugu & Kannada Voice AI Agent — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# LANGUAGE  (server-side default; can also be set per-session via ?language=)
# Options: telugu | kannada
# ─────────────────────────────────────────────────────────────────────────────
LANGUAGE=telugu


# ─────────────────────────────────────────────────────────────────────────────
# SONIOX API KEY  (cloud ASR — best accuracy)
# Get your free key at: https://soniox.com/dashboard
# When set   → Soniox cloud streaming ASR
#   Telugu  → language_code="te"
#   Kannada → language_code="kn"
# When NOT set → falls back to faster-whisper large-v3 on local GPU
# ─────────────────────────────────────────────────────────────────────────────
SONIOX_API_KEY=your-soniox-api-key-here

# Soniox model (stt-rt-v4 = current recommended real-time model)
SONIOX_MODEL=stt-rt-v4


# ─────────────────────────────────────────────────────────────────────────────
# LLM — Ollama (local GPU, open-source, NO API KEY REQUIRED)
#
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Run:     ollama serve
# Pull:    ollama pull qwen2.5:7b
#
# Model options by VRAM:
#   qwen2.5:7b    → ~6 GB VRAM   (good multilingual quality — default)
#   qwen2.5:14b   → ~10 GB VRAM  (better multilingual quality)
#   qwen2.5:32b   → ~20 GB VRAM  (best quality)
#   qwen2.5:72b   → ~48 GB VRAM  (best overall — 80GB GPU)
#   aya-expanse   → varies        (Cohere multilingual, Indian languages supported)
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_MAX_TOKENS=150


# ─────────────────────────────────────────────────────────────────────────────
# TTS — edge-tts voice overrides (optional)
#
# Telugu voice options (te-IN locale):
#   te-IN-ShrutiNeural   ← female (default Telugu)
#   te-IN-MohanNeural    ← male
#
# Kannada voice options (kn-IN locale):
#   kn-IN-SapnaNeural    ← female (default Kannada)
#   kn-IN-GaganNeural    ← male
# ─────────────────────────────────────────────────────────────────────────────
TTS_VOICE_TELUGU=te-IN-ShrutiNeural
TTS_VOICE_KANNADA=kn-IN-SapnaNeural


# ─────────────────────────────────────────────────────────────────────────────
# KANNADA TTS ENGINE PRIORITY
#
# Comma-separated list of engines tried in order for Kannada TTS.
# Available engines:
#   mms        — facebook/mms-tts-kan (local GPU, no API key needed)
#   elevenlabs — ElevenLabs REST API  (requires ELEVENLABS_API_KEY + voice IDs)
#   narakeet   — Narakeet REST API    (requires NARAKEET_API_KEY)
#   micmonster — MicMonster REST API  (requires MICMONSTER_API_KEY + voice ID)
#   speakatoo  — Speakatoo REST API   (requires SPEAKATOO_API_KEY + voice ID)
#   edge       — Microsoft edge-tts   (free, no key needed)
#   gtts       — Google gTTS          (free, uses Kannada kn)
#
# Examples:
#   Test ElevenLabs first:   KANNADA_TTS_ENGINE_PRIORITY=elevenlabs,edge,gtts
#   Test Narakeet first:     KANNADA_TTS_ENGINE_PRIORITY=narakeet,edge,gtts
#   Test MicMonster first:   KANNADA_TTS_ENGINE_PRIORITY=micmonster,edge,gtts
#   Test Speakatoo first:    KANNADA_TTS_ENGINE_PRIORITY=speakatoo,edge,gtts
#   Try all cloud services:  KANNADA_TTS_ENGINE_PRIORITY=elevenlabs,narakeet,micmonster,speakatoo,mms,edge,gtts
# ─────────────────────────────────────────────────────────────────────────────
KANNADA_TTS_ENGINE_PRIORITY=mms,edge,gtts


# ─────────────────────────────────────────────────────────────────────────────
# ELEVENLABS TTS  (https://elevenlabs.io)
# Supports high-quality multilingual Telugu and Kannada via eleven_multilingual_v2 model.
# Get your API key at: https://elevenlabs.io/app/settings/api-keys
# Find Telugu/Kannada-compatible voice IDs in the ElevenLabs voice library.
# ─────────────────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID_TELUGU_MALE=your-male-voice-id-here
ELEVENLABS_VOICE_ID_TELUGU_FEMALE=your-female-voice-id-here
ELEVENLABS_VOICE_ID_KANNADA_MALE=your-male-voice-id-here
ELEVENLABS_VOICE_ID_KANNADA_FEMALE=your-female-voice-id-here


# ─────────────────────────────────────────────────────────────────────────────
# NARAKEET TTS  (https://www.narakeet.com)
# Get your API key at: https://www.narakeet.com/app/text-to-speech-api/
# List available voices: GET https://api.narakeet.com/languages
# ─────────────────────────────────────────────────────────────────────────────
NARAKEET_API_KEY=your-narakeet-api-key-here
NARAKEET_VOICE_KANNADA=


# ─────────────────────────────────────────────────────────────────────────────
# MICMONSTER TTS  (https://micmonster.com)
# Get your API key at: https://micmonster.com/text-to-speech/
# Set the voice ID from MicMonster's Kannada voice list.
# ─────────────────────────────────────────────────────────────────────────────
MICMONSTER_API_KEY=your-micmonster-api-key-here
MICMONSTER_VOICE_ID_KANNADA=your-kannada-voice-id-here


# ─────────────────────────────────────────────────────────────────────────────
# SPEAKATOO TTS  (https://www.speakatoo.com)
# Get your API key at: https://www.speakatoo.com/
# Set the voice ID from Speakatoo's Kannada voice list.
# ─────────────────────────────────────────────────────────────────────────────
SPEAKATOO_API_KEY=your-speakatoo-api-key-here
SPEAKATOO_VOICE_ID_KANNADA=your-kannada-voice-id-here


# ─────────────────────────────────────────────────────────────────────────────
# RAG — FAISS knowledge base
# ─────────────────────────────────────────────────────────────────────────────
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_DOCS_DIR=./docs
RAG_INDEX_PATH=./faiss_index
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.3
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=50


# ─────────────────────────────────────────────────────────────────────────────
# Conversation memory
# ─────────────────────────────────────────────────────────────────────────────
MEMORY_MAX_TURNS=8


# ─────────────────────────────────────────────────────────────────────────────
# Audio / VAD
# Raise VAD_RMS_THRESHOLD to reduce false interrupts from background noise
# ─────────────────────────────────────────────────────────────────────────────
VAD_RMS_THRESHOLD=0.018


# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info
