# Optional debug dump for TTS A/B testing (disabled by default)
# When enabled, ElevenLabs source MP3 and decoded WAV are saved for comparison.
DEBUG_TTS_DUMP_AUDIO=false
DEBUG_TTS_DUMP_DIR=./debug_audio
# ─────────────────────────────────────────────────────────────────────────────
# Dari & Pashto Voice AI Agent — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# LANGUAGE  (server-side default; can also be set per-session via ?language=)
# Options: dari | pashto
# ─────────────────────────────────────────────────────────────────────────────
LANGUAGE=dari


# ─────────────────────────────────────────────────────────────────────────────
# SONIOX API KEY  (cloud ASR — best accuracy)
# Get your free key at: https://soniox.com/dashboard
# When set   → Soniox cloud streaming ASR
#   Dari   → language_code="fa"  (shared Persian code; app remains Dari-only)
#   Pashto → language_code="ps"
# When NOT set → falls back to faster-whisper large-v3 on local GPU
# ─────────────────────────────────────────────────────────────────────────────
SONIOX_API_KEY=your-soniox-api-key-here

# Soniox model (stt-rt-v4 = current recommended real-time model)
SONIOX_MODEL=stt-rt-v4


# ─────────────────────────────────────────────────────────────────────────────
# LLM — Ollama (local GPU, open-source, NO API KEY REQUIRED)
#
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Run:     ollama serve
# Pull:    ollama pull qwen2.5:7b
#
# Model options by VRAM:
#   qwen2.5:7b    → ~6 GB VRAM   (good Dari, reasonable Pashto — default)
#   qwen2.5:14b   → ~10 GB VRAM  (better multilingual quality)
#   qwen2.5:32b   → ~20 GB VRAM  (best Dari quality)
#   qwen2.5:72b   → ~48 GB VRAM  (best overall — 80GB GPU)
#   aya-expanse   → varies        (Cohere multilingual, Persian supported)
#
# Pashto-specific fine-tuned model (optional, requires manual GGUF setup):
#   junaid008/qehwa-pashto-llm  ← Apache 2.0, Qwen2.5-7B fine-tuned for Pashto
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_MAX_TOKENS=150


# ─────────────────────────────────────────────────────────────────────────────
# TTS — edge-tts voice overrides (optional — mainly for Pashto/testing)
#
# Dari is enforced as strict MMS Dari at runtime (no edge/gTTS fallback).
# These Dari edge values are kept only for compatibility/testing and are not
# used in strict Dari mode.
#   fa-IR-DilaraNeural   ← female (compat only)
#   fa-IR-FaridNeural    ← male (compat only)
#
# Pashto voice options (ps-AF locale — Afghan Pashto):
#   ps-AF-LatifaNeural   ← female (default Pashto)
#   ps-AF-GulNawazNeural ← male
# ─────────────────────────────────────────────────────────────────────────────
TTS_VOICE_DARI=fa-IR-DilaraNeural
TTS_VOICE_PASHTO=ps-AF-LatifaNeural


# ─────────────────────────────────────────────────────────────────────────────
# PASHTO TTS ENGINE PRIORITY
#
# Comma-separated list of engines tried in order for Pashto TTS.
# Available engines:
#   mms        — facebook/mms-tts-pbt (local GPU, no API key needed)
#   elevenlabs — ElevenLabs REST API  (requires ELEVENLABS_API_KEY + voice IDs)
#   narakeet   — Narakeet REST API    (requires NARAKEET_API_KEY)
#   micmonster — MicMonster REST API  (requires MICMONSTER_API_KEY + voice ID)
#   speakatoo  — Speakatoo REST API   (requires SPEAKATOO_API_KEY + voice ID)
#   edge       — Microsoft edge-tts   (free, no key needed)
#   gtts       — Google gTTS          (free, uses Persian fa as proxy)
#
# Examples:
#   Test ElevenLabs first:   PASHTO_TTS_ENGINE_PRIORITY=elevenlabs,edge,gtts
#   Test Narakeet first:     PASHTO_TTS_ENGINE_PRIORITY=narakeet,edge,gtts
#   Test MicMonster first:   PASHTO_TTS_ENGINE_PRIORITY=micmonster,edge,gtts
#   Test Speakatoo first:    PASHTO_TTS_ENGINE_PRIORITY=speakatoo,edge,gtts
#   Try all cloud services:  PASHTO_TTS_ENGINE_PRIORITY=elevenlabs,narakeet,micmonster,speakatoo,mms,edge,gtts
# ─────────────────────────────────────────────────────────────────────────────
PASHTO_TTS_ENGINE_PRIORITY=mms,edge,gtts
# Note: ElevenLabs multilingual model has higher noise floor for Pashto vs
# the dedicated MMS local model. Use elevenlabs via the UI engine selector
# only when you want to compare — MMS is the cleanest default.


# ─────────────────────────────────────────────────────────────────────────────
# ELEVENLABS TTS  (https://elevenlabs.io)
# Supports high-quality multilingual Pashto via eleven_multilingual_v2 model.
# Get your API key at: https://elevenlabs.io/app/settings/api-keys
# Find Pashto-compatible voice IDs in the ElevenLabs voice library.
# ─────────────────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID_PASHTO_MALE=your-male-voice-id-here
ELEVENLABS_VOICE_ID_PASHTO_FEMALE=your-female-voice-id-here


# ─────────────────────────────────────────────────────────────────────────────
# NARAKEET TTS  (https://www.narakeet.com)
# Has dedicated Afghan Pashto voices (hamid, zeba, etc.)
# Get your API key at: https://www.narakeet.com/app/text-to-speech-api/
# List available Pashto voices: GET https://api.narakeet.com/languages
# ─────────────────────────────────────────────────────────────────────────────
NARAKEET_API_KEY=your-narakeet-api-key-here
NARAKEET_VOICE_PASHTO=hamid


# ─────────────────────────────────────────────────────────────────────────────
# MICMONSTER TTS  (https://micmonster.com)
# Pashto (Afghanistan) voices available.
# Get your API key at: https://micmonster.com/text-to-speech/
# Set the voice ID from MicMonster's Pashto voice list.
# ─────────────────────────────────────────────────────────────────────────────
MICMONSTER_API_KEY=your-micmonster-api-key-here
MICMONSTER_VOICE_ID_PASHTO=your-pashto-voice-id-here


# ─────────────────────────────────────────────────────────────────────────────
# SPEAKATOO TTS  (https://www.speakatoo.com)
# Male & female Pashto voices available.
# Get your API key at: https://www.speakatoo.com/
# Set the voice ID from Speakatoo's Pashto voice list.
# ─────────────────────────────────────────────────────────────────────────────
SPEAKATOO_API_KEY=your-speakatoo-api-key-here
SPEAKATOO_VOICE_ID_PASHTO=your-pashto-voice-id-here


# ─────────────────────────────────────────────────────────────────────────────
# RAG — FAISS knowledge base
# ─────────────────────────────────────────────────────────────────────────────
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_DOCS_DIR=./docs
RAG_INDEX_PATH=./faiss_index
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.3
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=50


# ─────────────────────────────────────────────────────────────────────────────
# Conversation memory
# ─────────────────────────────────────────────────────────────────────────────
MEMORY_MAX_TURNS=8


# ─────────────────────────────────────────────────────────────────────────────
# Audio / VAD
# Raise VAD_RMS_THRESHOLD to reduce false interrupts from background noise
# ─────────────────────────────────────────────────────────────────────────────
VAD_RMS_THRESHOLD=0.018


# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info
