# ─────────────────────────────────────────────────────────────────────────────
# Telugu & Kannada Voice AI Agent — Environment Variables
# Copy this file to .env and fill in the values you have.
# Keys you leave empty are safely skipped — no errors.
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# LANGUAGE  (server-side default; overridden per-session via ?language=)
# Options: telugu | kannada
# ─────────────────────────────────────────────────────────────────────────────
LANGUAGE=telugu


# =============================================================================
# LLM — Ollama (local GPU, open-source, NO API KEY REQUIRED)
#
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Run:     ollama serve
# Pull:    ollama pull qwen2.5:72b
#
# Model options by VRAM:
#   qwen2.5:7b    → ~6 GB VRAM   (good multilingual quality)
#   qwen2.5:14b   → ~10 GB VRAM  (better multilingual quality)
#   qwen2.5:32b   → ~20 GB VRAM  (best quality)
#   qwen2.5:72b   → ~48 GB VRAM  (best overall — 80GB GPU)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:72b
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_MAX_TOKENS=100


# =============================================================================
# STT (Speech-to-Text)
#
# STT_ENGINE selects the default engine for all sessions.
# Override per-session via WebSocket query: ?stt_engine=azure
#
# Options: auto | sarvam | soniox | google | azure | amazon | whisper
#   auto    — priority chain: Sarvam (if key) → Soniox (if key) → Whisper
#   sarvam  — Sarvam AI (best for Indian languages)
#   soniox  — Soniox cloud streaming (real-time partials)
#   google  — Google Cloud STT
#   azure   — Microsoft Azure STT
#   amazon  — Amazon Transcribe
#   whisper — local faster-whisper large-v3 (no internet needed)
# =============================================================================
STT_ENGINE=auto


# ─────────────────────────────────────────────────────────────────────────────
# Sarvam AI STT  (best for Telugu & Kannada — primary recommended)
# Docs: https://docs.sarvam.ai/api-reference/endpoints/speech-to-text
# Get key: https://dashboard.sarvam.ai
# Same key is used for Sarvam TTS below.
# ─────────────────────────────────────────────────────────────────────────────
SARVAM_API_KEY=your-sarvam-api-key-here
SARVAM_STT_MODEL=saarika:v2.5


# ─────────────────────────────────────────────────────────────────────────────
# Soniox STT  (cloud streaming, real-time partial transcripts)
# Docs: https://soniox.com/docs
# Get key: https://soniox.com/dashboard
# ─────────────────────────────────────────────────────────────────────────────
SONIOX_API_KEY=your-soniox-api-key-here
SONIOX_MODEL=stt-rt-v4


# ─────────────────────────────────────────────────────────────────────────────
# Google Cloud STT
# Docs: https://cloud.google.com/speech-to-text
# Get key: https://console.cloud.google.com/apis/credentials
# Enable: Cloud Speech-to-Text API in your GCP project
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_STT_API_KEY=your-google-stt-api-key-here


# ─────────────────────────────────────────────────────────────────────────────
# Microsoft Azure STT
# Docs: https://learn.microsoft.com/en-us/azure/ai-services/speech-service/rest-speech-to-text
# Get key: Azure Portal → Speech service → Keys and Endpoint
# Region: extract from your endpoint URL, e.g. "centralindia" from
#         https://centralindia.api.cognitive.microsoft.com/
# ─────────────────────────────────────────────────────────────────────────────
AZURE_STT_KEY=your-azure-speech-key-here
AZURE_STT_REGION=centralindia


# ─────────────────────────────────────────────────────────────────────────────
# Amazon Transcribe STT
# Docs: https://docs.aws.amazon.com/transcribe/latest/dg/streaming.html
# Install: pip install amazon-transcribe
# AWS credentials are shared with Amazon Polly TTS below.
# ─────────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_REGION_NAME=us-east-1


# =============================================================================
# TTS (Text-to-Speech)
#
# Comma-separated priority list — first engine that succeeds wins.
# Options: sarvam | azure_tts | google_tts | amazon_polly | elevenlabs |
#          gnani | ttsmaker | edge | gtts | mms
#
# edge and gtts are always free (no key needed) — good final fallbacks.
# =============================================================================
TELUGU_TTS_ENGINE_PRIORITY=azure_tts,sarvam,edge,gtts
KANNADA_TTS_ENGINE_PRIORITY=azure_tts,sarvam,edge,gtts

# TTS voice selection (used by edge-tts fallback)
TTS_VOICE_TELUGU=te-IN-ShrutiNeural
TTS_VOICE_KANNADA=kn-IN-SapnaNeural


# ─────────────────────────────────────────────────────────────────────────────
# Sarvam AI TTS  (https://sarvam.ai — best quality for Telugu & Kannada)
# Get key: https://dashboard.sarvam.ai  (same key as Sarvam STT above)
#
# Telugu female speakers: anushka, manisha, vidya, arya, priya, neha, pooja,
#                         simra, kavya, ishita, shreya, roopa, tanya, suhani
# Telugu male speakers:   abhilash, karun, hitesh, aditya, rahul, rohan, amit,
#                         dev, ratan, varun, manan, sumit, kabir, aayan
# Kannada: same speaker pool — bulbul:v2 supports kn-IN
#
# SARVAM_PACE: 0.5 (slow) → 1.0 (normal) → 2.0 (fast)
# ─────────────────────────────────────────────────────────────────────────────
SARVAM_MODEL=bulbul:v2
SARVAM_PACE=1.0
SARVAM_SPEAKER_TELUGU=anushka
SARVAM_SPEAKER_TELUGU_MALE=abhilash
SARVAM_SPEAKER_KANNADA=anushka
SARVAM_SPEAKER_KANNADA_MALE=abhilash


# ─────────────────────────────────────────────────────────────────────────────
# Microsoft Azure TTS
# Docs: https://learn.microsoft.com/en-us/azure/ai-services/speech-service/rest-text-to-speech
# Get key: Azure Portal → Speech service → Keys and Endpoint
# Same key and region as Azure STT above.
#
# Telugu voices: te-IN-ShrutiNeural (female), te-IN-MohanNeural (male)
# Kannada voices: kn-IN-SapnaNeural (female), kn-IN-GaganNeural (male)
# ─────────────────────────────────────────────────────────────────────────────
AZURE_TTS_KEY=your-azure-speech-key-here
AZURE_TTS_REGION=centralindia
AZURE_TTS_VOICE_TELUGU=te-IN-ShrutiNeural
AZURE_TTS_VOICE_TELUGU_MALE=te-IN-MohanNeural
AZURE_TTS_VOICE_KANNADA=kn-IN-SapnaNeural
AZURE_TTS_VOICE_KANNADA_MALE=kn-IN-GaganNeural


# ─────────────────────────────────────────────────────────────────────────────
# Google Cloud TTS
# Docs: https://cloud.google.com/text-to-speech
# Get key: https://console.cloud.google.com/apis/credentials
# Enable: Cloud Text-to-Speech API in your GCP project
#
# Telugu voices: te-IN-Standard-A (female), te-IN-Standard-B (male)
#                te-IN-Wavenet-A  (female), te-IN-Wavenet-B  (male)
# Kannada voices: kn-IN-Standard-A (female), kn-IN-Standard-B (male)
#                 kn-IN-Wavenet-A  (female), kn-IN-Wavenet-B  (male)
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_TTS_API_KEY=your-google-tts-api-key-here
GOOGLE_TTS_VOICE_TELUGU=te-IN-Standard-A
GOOGLE_TTS_VOICE_TELUGU_MALE=te-IN-Standard-B
GOOGLE_TTS_VOICE_KANNADA=kn-IN-Standard-A
GOOGLE_TTS_VOICE_KANNADA_MALE=kn-IN-Standard-B


# ─────────────────────────────────────────────────────────────────────────────
# ElevenLabs TTS
# Docs: https://elevenlabs.io/docs/api-reference
# Get key: https://elevenlabs.io/app/settings/api-keys
# ─────────────────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID_TELUGU_FEMALE=onwK4e9ZLuTAKqWW03F9
ELEVENLABS_VOICE_ID_TELUGU_MALE=iP95p4xoKVk53GoZ742B
ELEVENLABS_VOICE_ID_KANNADA_FEMALE=onwK4e9ZLuTAKqWW03F9
ELEVENLABS_VOICE_ID_KANNADA_MALE=iP95p4xoKVk53GoZ742B


# ─────────────────────────────────────────────────────────────────────────────
# Amazon Polly TTS
# Docs: https://docs.aws.amazon.com/polly/latest/dg/voicelist.html
# AWS credentials shared with Amazon Transcribe STT above.
# Note: Polly has no dedicated Telugu/Kannada voice — uses Aditi (hi-IN) as
# closest Indian-accent fallback. Check AWS docs for updates.
# ─────────────────────────────────────────────────────────────────────────────
AWS_POLLY_VOICE_TELUGU=Aditi
AWS_POLLY_VOICE_TELUGU_MALE=Aditi
AWS_POLLY_LANGUAGE_TELUGU=hi-IN
AWS_POLLY_VOICE_KANNADA=Aditi
AWS_POLLY_VOICE_KANNADA_MALE=Aditi
AWS_POLLY_LANGUAGE_KANNADA=hi-IN
AWS_POLLY_ENGINE=standard


# ─────────────────────────────────────────────────────────────────────────────
# Gnani.ai TTS  (https://gnani.ai — Indian language specialist)
# Contact: https://gnani.ai/contact
# ─────────────────────────────────────────────────────────────────────────────
GNANI_API_KEY=your-gnani-api-key-here
GNANI_CLIENT_ID=
GNANI_VOICE_TELUGU=female
GNANI_VOICE_KANNADA=female


# ─────────────────────────────────────────────────────────────────────────────
# TTSMaker  (https://ttsmaker.com — free tier: 20,000 chars/month)
# Get token: https://ttsmaker.com/api
# Find voice IDs: GET https://api.ttsmaker.com/v1/get-voice-list
# ─────────────────────────────────────────────────────────────────────────────
TTSMAKER_TOKEN=your-ttsmaker-token-here
TTSMAKER_VOICE_ID_TELUGU=0
TTSMAKER_VOICE_ID_KANNADA=0


# ─────────────────────────────────────────────────────────────────────────────
# Narakeet TTS  (https://www.narakeet.com)
# Get key: https://www.narakeet.com/app/text-to-speech-api/
# ─────────────────────────────────────────────────────────────────────────────
NARAKEET_API_KEY=your-narakeet-api-key-here
NARAKEET_VOICE_KANNADA=


# ─────────────────────────────────────────────────────────────────────────────
# MicMonster TTS  (https://micmonster.com)
# ─────────────────────────────────────────────────────────────────────────────
MICMONSTER_API_KEY=your-micmonster-api-key-here
MICMONSTER_VOICE_ID_KANNADA=your-kannada-voice-id-here


# ─────────────────────────────────────────────────────────────────────────────
# Speakatoo TTS  (https://www.speakatoo.com)
# ─────────────────────────────────────────────────────────────────────────────
SPEAKATOO_API_KEY=your-speakatoo-api-key-here
SPEAKATOO_VOICE_ID_KANNADA=your-kannada-voice-id-here


# edge-tts and gTTS are free — no API key needed.


# =============================================================================
# RAG — FAISS knowledge base
# =============================================================================
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_DOCS_DIR=./docs
RAG_INDEX_PATH=./faiss_index
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.3
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=50


# =============================================================================
# Memory
# =============================================================================
MEMORY_MAX_TURNS=20


# =============================================================================
# Audio / VAD
# Raise VAD_RMS_THRESHOLD to reduce false interrupts from background noise.
# =============================================================================
VAD_RMS_THRESHOLD=0.018


# =============================================================================
# Server
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info


# =============================================================================
# Debug
# =============================================================================
DEBUG_TTS_DUMP_AUDIO=false
DEBUG_TTS_DUMP_DIR=./debug_audio
