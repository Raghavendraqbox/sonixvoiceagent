# ─────────────────────────────────────────────────────────────────────────────
# Telugu Voice AI Agent — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# SONIOX API KEY  (Telugu ASR — best accuracy)
# Get your free key at: https://soniox.com/dashboard
# When set   → Soniox cloud streaming ASR (recommended for Telugu)
# When NOT set → falls back to faster-whisper large-v3 on local GPU
# ─────────────────────────────────────────────────────────────────────────────
SONIOX_API_KEY=your-soniox-api-key-here

# Soniox language code and model
SONIOX_LANGUAGE=te
SONIOX_MODEL=soniox_multilingual_2


# ─────────────────────────────────────────────────────────────────────────────
# LLM — Ollama (local GPU, open-source, NO API KEY REQUIRED)
#
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Run:     ollama serve
# Pull:    ollama pull qwen2.5:32b
#
# Model options by VRAM:
#   qwen2.5:72b  → ~48 GB VRAM  (best Telugu on 80GB GPU — default)
#   gemma4:31b   → ~63 GB VRAM  (Google Gemma 4, Apr 2026 — upgrade option)
#   qwen2.5:32b  → ~20 GB VRAM  (good for smaller GPUs)
#   qwen2.5:14b  → ~10 GB VRAM  (lighter option)
#   gemma3:27b   → ~55 GB VRAM  (Google Gemma 3)
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:72b
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_MAX_TOKENS=150


# ─────────────────────────────────────────────────────────────────────────────
# TTS — Telugu voice (edge-tts, free, NO API KEY REQUIRED)
# Options:
#   te-IN-ShrutiNeural   ← female (default, recommended)
#   te-IN-MohanNeural    ← male
# ─────────────────────────────────────────────────────────────────────────────
TTS_VOICE=te-IN-ShrutiNeural


# ─────────────────────────────────────────────────────────────────────────────
# RAG — FAISS knowledge base
# ─────────────────────────────────────────────────────────────────────────────
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_DOCS_DIR=./docs
RAG_INDEX_PATH=./faiss_index
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.3
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=50


# ─────────────────────────────────────────────────────────────────────────────
# Conversation memory
# ─────────────────────────────────────────────────────────────────────────────
MEMORY_MAX_TURNS=8


# ─────────────────────────────────────────────────────────────────────────────
# Audio / VAD
# Raise VAD_RMS_THRESHOLD to reduce false interrupts from background noise
# ─────────────────────────────────────────────────────────────────────────────
VAD_RMS_THRESHOLD=0.018


# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info
